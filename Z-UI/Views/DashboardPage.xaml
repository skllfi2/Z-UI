<Page
    x:Class="ZUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="http://www.w3.org/2000/svg"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="24,16,24,24">

            <!-- ── Карточка статуса + фильтры ── -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Статус и кнопка -->
                    <Grid Grid.Row="0" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="52" Height="52" CornerRadius="12"
                                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xEA18;" FontSize="24"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="StatusZaschity" Text="Статус защиты"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.5"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusIndicator" Width="10" Height="10"
                                             Fill="Red" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="StatusText" x:Name="StatusText" Text="Остановлено"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1"
                                       Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                       HorizontalAlignment="Stretch" Opacity="0.4"/>

                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="AktivnayaStrategiya" Text="Активная стратегия"
                                           Style="{ThemeResource TitleTextBlockStyle}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemBaseHighColorBrush}"/>

                                <Border CornerRadius="8" Padding="16" Background="{ThemeResource SystemAccentFillColorAltHighBrush}">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="&#xE8CB;" FontSize="20" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock x:Name="StrategyText" Text="General"
                                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Uid="StrategyDescription" Text="Стандартная протекция для обхода популярных сетей"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <HyperlinkButton Grid.Column="2" Content="→"
                                                         FontSize="16"
                                                         Click="ChangeStrategy_Click"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button x:Uid="ToggleButton" x:Name="ToggleButton"
                                Grid.Column="2"
                                Content="&#x25B6;  Запустить"
                                Style="{ThemeResource AccentButtonStyle}"
                                Padding="20,12"
                                MinWidth="140"
                                VerticalAlignment="Center"
                                Click="ToggleButton_Click"/>
                    </Grid>

                    <!-- Разделитель -->
                    <Rectangle Grid.Row="1" Height="1"
                               Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                               HorizontalAlignment="Stretch" Opacity="0.5"/>

                    <!-- Фильтры -->
                    <Grid Grid.Row="2" ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="GameFilter" Text="Game Filter"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="ObkhodDpiNaIgrovyePorty102465535" Text="Обход DPI на игровые порты (1024–65535)"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="GameFilterComboBox" Grid.Column="1"
                                  MinWidth="160" VerticalAlignment="Center"
                                  SelectionChanged="GameFilterComboBox_SelectionChanged">
                            <ComboBoxItem x:Uid="Otklyuchyon" Content="Отключён"  Tag="disabled"/>
                            <ComboBoxItem x:Uid="TcpIUdp" Content="TCP и UDP" Tag="all"/>
                            <ComboBoxItem x:Uid="TolkoTcp" Content="Только TCP" Tag="tcp"/>
                            <ComboBoxItem x:Uid="TolkoUdp" Content="Только UDP" Tag="udp"/>
                        </ComboBox>

                        <Rectangle Grid.Column="2" Width="1" Margin="0,0,0,0"
                                   Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                   Opacity="0.5" VerticalAlignment="Stretch"/>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="IpsetFilter" Text="IPSet Filter"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="IpsetStatusText" x:Name="IpsetStatusText" Text="Загружен список IP"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="IpsetFilterComboBox" Grid.Column="4"
                                  MinWidth="160" VerticalAlignment="Center"
                                  SelectionChanged="IpsetFilterComboBox_SelectionChanged">
                            <ComboBoxItem x:Uid="LyuboyIpAny" Content="Любой IP (any)"           Tag="any"/>
                            <ComboBoxItem x:Uid="TolkoIzSpiskaLoaded" Content="Только из списка (loaded)" Tag="loaded"/>
                            <ComboBoxItem x:Uid="NikakoyNone" Content="Никакой (none)"            Tag="none"/>
                        </ComboBox>
                    </Grid>

                </Grid>
            </Border>

            <!-- ── Карточки сервисов ── -->
            <TextBlock x:Uid="Servisy" Text="СЕРВИСЫ"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.45" CharacterSpacing="80"
                       Margin="2,4,0,0"/>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1A5865F2" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE9EA;" FontSize="22" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            </Border>
                            <Ellipse x:Name="DiscordIndicator" Grid.Column="1"
                                     Width="8" Height="8"
                                     Fill="{ThemeResource SystemFillColorCriticalBrush}"
                                     VerticalAlignment="Top"/>
                        </Grid>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="Discord" Text="Discord" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="DiscordStatus" x:Name="DiscordStatus" Text="Защита выключена"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.55"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1AFF0000" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xEA14;" FontSize="22" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </Border>
                            <Ellipse x:Name="YoutubeIndicator" Grid.Column="1"
                                     Width="8" Height="8"
                                     Fill="{ThemeResource SystemFillColorCriticalBrush}"
                                     VerticalAlignment="Top"/>
                        </Grid>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="Youtube" Text="YouTube" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="YoutubeStatus" x:Name="YoutubeStatus" Text="Защита выключена"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.55"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#1A4285F4" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE774;" FontSize="22" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            </Border>
                            <Ellipse x:Name="GoogleIndicator" Grid.Column="1"
                                     Width="8" Height="8"
                                     Fill="{ThemeResource SystemFillColorCriticalBrush}"
                                     VerticalAlignment="Top"/>
                        </Grid>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="Google" Text="Google" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="GoogleStatus" x:Name="GoogleStatus" Text="Защита выключена"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.55"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Баннер: zapret не установлен ── -->
            <InfoBar x:Name="SetupRequiredBar"
                     IsOpen="False"
                     IsClosable="False"
                     Severity="Warning"
                     Title="zapret не установлен"
                     Message="Для работы защиты необходимо установить zapret через мастер настройки.">
                <InfoBar.ActionButton>
                    <Button Content="Запустить мастер настройки"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="OpenWizard_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- ── InfoBar обновления ── -->
            <InfoBar x:Name="UpdateInfoBar"
                     IsOpen="False" IsClosable="True"
                     Severity="Informational"
                     Title="Доступно обновление">
                <InfoBar.ActionButton>
                    <HyperlinkButton x:Uid="PereytiKObnovleniyam" Content="Перейти к обновлениям &#x2192;"
                                     Click="UpdateBanner_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

        </StackPanel>
    </ScrollViewer>
</Page>
