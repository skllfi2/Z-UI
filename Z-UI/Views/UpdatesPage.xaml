<Page
    x:Class="ZUI.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

<ScrollViewer Padding="24">
 <StackPanel Spacing="16" HorizontalAlignment="Stretch">
 <InfoBar
                IsOpen="{x:Bind ViewModel.UpdateAvailable, Mode=OneWay}"
                IsClosable="True"
                Severity="Warning"
                Title="Доступно обновление"
                Message="{x:Bind ViewModel.LatestVersion, Mode=OneWay}" />

            <StackPanel Spacing="8">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Локальная версия:" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.LocalVersion, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Последняя версия:" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Content="Проверить обновления"
                    Command="{x:Bind ViewModel.CheckCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</Page>
