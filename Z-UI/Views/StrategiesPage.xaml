<Page
x:Class="ZUI.Views.StrategiesPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="using:ZUI.ViewModels"
xmlns:vm="using:ZUI.ViewModels"
mc:Ignorable="d">

<Page.Resources>
<vm:LocalizationViewModel x:Key="L"/>
</Page.Resources>

<Grid Margin="24,16,24,24">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="2*" MinWidth="200" MaxWidth="320"/>
<ColumnDefinition Width="20"/>
<ColumnDefinition Width="3*"/>
</Grid.ColumnDefinitions>

<!-- Левая панель — список стратегий -->
<Grid Grid.Column="0">
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="8"/>
<RowDefinition Height="*"/>
</Grid.RowDefinitions>

<!-- Поиск и кнопка сброса -->
<Grid Grid.Row="0">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<AutoSuggestBox Grid.Column="0" PlaceholderText="{Binding SearchStrategy, Source={StaticResource L}}" QueryIcon="Find"
Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"/>

<Button Grid.Column="1" ToolTipService.ToolTip="{Binding ResetTestResults, Source={StaticResource L}}"
Command="{x:Bind ViewModel.ClearRatingsCommand}" Padding="8" Margin="8,0,0,0">
<FontIcon Glyph="&#xE894;" FontSize="14"/>
</Button>
</Grid>

<!-- Список -->
<Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
BorderThickness="1" CornerRadius="8">
<ListView ItemsSource="{x:Bind ViewModel.Strategies, Mode=OneWay}"
SelectedItem="{x:Bind ViewModel.SelectedStrategy, Mode=TwoWay}"
SelectionMode="Single" Background="Transparent"
BorderThickness="0">
<ListView.ItemContainerStyle>
<Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
<Setter Property="Padding" Value="14,8"/>
<Setter Property="MinHeight" Value="44"/>
<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
</Style>
</ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:StrategyItem">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" FontSize="18"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="4,0"/>

                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}" VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" Style="{ThemeResource BodyTextBlockStyle}"/>

                                <Border Grid.Column="2" Background="{x:Bind RatingBackground}" CornerRadius="10"
                                    Padding="7,2,7,2" VerticalAlignment="Center"
                                    ToolTipService.ToolTip="{x:Bind RatingTooltip}"
                                    Visibility="{x:Bind RatingVisible}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{x:Bind RatingEmoji}" FontSize="11" Foreground="{x:Bind RatingForeground}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind RatingShortLabel}" FontSize="11" Foreground="{x:Bind RatingForeground}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
</ListView>
</Border>
</Grid>

<!-- Правая панель -->
<Grid Grid.Column="2">
<!-- Пустое состояние -->
<StackPanel Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
<Border Width="120" Height="120" CornerRadius="60"
Background="{ThemeResource SubtleFillColorSecondaryBrush}"
HorizontalAlignment="Center">
<FontIcon Glyph="&#xE8FD;" FontSize="48"
Foreground="{ThemeResource TextFillColorSecondaryBrush}"
HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>
<StackPanel Spacing="4" HorizontalAlignment="Center">
<TextBlock Text="{Binding SelectStrategyTitle, Source={StaticResource L}}"
Style="{ThemeResource SubtitleTextBlockStyle}"
HorizontalAlignment="Center"
FontWeight="SemiBold"/>
<TextBlock Text="{Binding SelectStrategyHint, Source={StaticResource L}}"
Style="{ThemeResource CaptionTextBlockStyle}"
Opacity="0.5"
HorizontalAlignment="Center"
TextWrapping="Wrap"
MaxWidth="280"
TextAlignment="Center"/>
</StackPanel>
</StackPanel>

<!-- Контент выбранной стратегии -->
<Grid Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>

<!-- Заголовок стратегии -->
<Grid Grid.Row="0" ColumnSpacing="16">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="*"/>
</Grid.ColumnDefinitions>

<Border Grid.Column="0" Width="64" Height="64" CornerRadius="12"
Background="{x:Bind ViewModel.SelectedStrategyIconColor, Mode=OneWay}">
<FontIcon Glyph="{x:Bind ViewModel.SelectedStrategyIconGlyph, Mode=OneWay}" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>

<StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
<TextBlock Text="{x:Bind ViewModel.SelectedStrategyName, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}"/>
<TextBlock Text="{x:Bind ViewModel.SelectedStrategyDescription, Mode=OneWay}"
Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" TextWrapping="Wrap"/>
</StackPanel>
</Grid>

<!-- Прокручиваемый контент -->
<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
<StackPanel Spacing="8">
<!-- Статус активной стратегии -->
<InfoBar IsOpen="{x:Bind ViewModel.SelectedStrategyIsActive, Mode=OneWay}"
IsClosable="False" Severity="Success" CornerRadius="8"
Title="{Binding ActiveStrategy, Source={StaticResource L}}" Message="{Binding ActiveStrategyDesc, Source={StaticResource L}}"/>

            <!-- Карточка результата теста -->
            <Border CornerRadius="8" Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{x:Bind ViewModel.SelectedStrategyHasRating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10"
                        Padding="12,6,12,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind ViewModel.SelectedStrategyRatingEmoji, Mode=OneWay}" FontSize="14"
                                Foreground="{x:Bind ViewModel.SelectedStrategyRatingForeground, Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedStrategyRatingShortLabel, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                Foreground="{x:Bind ViewModel.SelectedStrategyRatingForeground, Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TestResult, Source={StaticResource L}}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedStrategyRating, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

<!-- Тип стратегии -->
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
BorderThickness="1" CornerRadius="8" Padding="14,12">
<Grid ColumnSpacing="12">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="*"/>
</Grid.ColumnDefinitions>
<Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
Background="{ThemeResource SubtleFillColorSecondaryBrush}" VerticalAlignment="Center">
<FontIcon Glyph="&#xE9F5;" FontSize="14" Opacity="0.7"/>
</Border>
<StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
<TextBlock Text="{Binding StrategyType, Source={StaticResource L}}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
<TextBlock Text="{x:Bind ViewModel.SelectedStrategyType, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
</StackPanel>
</Grid>
</Border>

<!-- Применимость -->
<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
BorderThickness="1" CornerRadius="8" Padding="14,12">
<Grid ColumnSpacing="12">
<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="*"/>
</Grid.ColumnDefinitions>
<Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
Background="{ThemeResource SubtleFillColorSecondaryBrush}" VerticalAlignment="Top">
<FontIcon Glyph="&#xE946;" FontSize="14" Opacity="0.7"/>
</Border>
<StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
<TextBlock Text="{Binding RecommendedFor, Source={StaticResource L}}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
<TextBlock Text="{x:Bind ViewModel.SelectedStrategyRecommendedFor, Mode=OneWay}" TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
</StackPanel>
</Grid>
</Border>
</StackPanel>
</ScrollViewer>

<!-- Кнопка применения -->
<Button Grid.Row="2" Content="{Binding ApplyStrategy, Source={StaticResource L}}"
Command="{x:Bind ViewModel.ApplyStrategyCommand}"
HorizontalAlignment="Stretch" Margin="0,16,0,0"
Style="{ThemeResource AccentButtonStyle}"/>
</Grid>
</Grid>
</Grid>
</Page>
