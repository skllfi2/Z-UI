<Page
    x:Class="ZUI.Views.ServicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

<ScrollViewer Padding="24">
 <StackPanel Spacing="16" HorizontalAlignment="Stretch">
 <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="{x:Bind ViewModel.Status, Mode=OneWay}"
                Message="Текущий статус сервиса" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Установить"
                        Command="{x:Bind ViewModel.InstallServiceCommand}"
                        Width="120" />
                <Button Content="Удалить"
                        Command="{x:Bind ViewModel.RemoveServiceCommand}"
                        Width="120"
                        Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Обновить статус"
                        Command="{x:Bind ViewModel.RefreshStatusCommand}"
                        Width="140" />
            </StackPanel>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Лог операций" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ListView ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}"
                              MaxHeight="300"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" FontFamily="Consolas" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
