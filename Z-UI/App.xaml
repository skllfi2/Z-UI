<Application
x:Class="ZUI.App"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:converters="using:ZUI.Converters">
<Application.Resources>
<ResourceDictionary>
<ResourceDictionary.MergedDictionaries>
<XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
</ResourceDictionary.MergedDictionaries>

<!-- Шрифты Windows 11 -->
<FontFamily x:Key="AppFontFamily">Segoe UI Variable Text</FontFamily>
<FontFamily x:Key="AppFontDisplay">Segoe UI Variable Display</FontFamily>
<FontFamily x:Key="AppFontMono">Cascadia Mono, Consolas, monospace</FontFamily>

<!-- Размеры -->
<x:Double x:Key="FontSizeSmall">11</x:Double>
<x:Double x:Key="FontSizeBody">14</x:Double>
<x:Double x:Key="FontSizeSubtitle">18</x:Double>
<x:Double x:Key="FontSizeTitle">28</x:Double>

<!-- Базовый стиль TextBlock -->
<Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
<Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
<Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
</Style>

 <!-- Конвертеры -->
 <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
 <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
 <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
 <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
 <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
 <converters:BoolToInfoBarSeverityConverter x:Key="BoolToInfoBarSeverityConverter" />
 <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
 <converters:BoolToGreenRedColorConverter x:Key="BoolToGreenRedColorConverter" />
 <converters:BoolToStartStopConverter x:Key="BoolToStartStopConverter" />
 <converters:BoolToPlayStopGlyphConverter x:Key="BoolToPlayStopGlyphConverter" />
 <converters:BoolToTextWrappingConverter x:Key="BoolToTextWrappingConverter" />
 <converters:BoolToCheckGlyphConverter x:Key="BoolToCheckGlyphConverter" />
 <converters:StringCollectionConverter x:Key="StringCollectionConverter" />
 <converters:ThemeToBoolConverter x:Key="ThemeToBoolConverter" />
 <converters:LanguageToBoolConverter x:Key="LanguageToBoolConverter" />
	<converters:ProgressToPercentConverter x:Key="ProgressToPercentConverter" />
	<converters:BoolToStopPlayGlyphConverter x:Key="BoolToStopPlayGlyphConverter" />
	<converters:BoolToCollapseExpandGlyphConverter x:Key="BoolToCollapseExpandGlyphConverter" />
	<converters:BoolToCollapseExpandTextConverter x:Key="BoolToCollapseExpandTextConverter" />
	<converters:BoolToAccentMutedColorConverter x:Key="BoolToAccentMutedColorConverter" />
	<converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />

<!-- Accent Button -->
<Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
<Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
</Style>
</ResourceDictionary>
</Application.Resources>
</Application>
